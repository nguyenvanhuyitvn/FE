-- a) Liệt kê HoTen, Lop và điểm trung bình (làm tròn đến 2 chữ số thập phân) của từng sinh viên.
-- Chỉ hiển thị những sinh viên có điểm trung bình >= 7.0.

SELECT 
    SV.HoTen, 
    SV.Lop, 
    ROUND(AVG(K.Diem), 2) AS DiemTrungBinh
FROM SINHVIEN SV
JOIN KETQUA K ON SV.MaSV = K.MaSV
GROUP BY SV.MaSV, SV.HoTen, SV.Lop
HAVING AVG(K.Diem) >= 7.0;

-- b) Tìm HoTen và Lop của sinh viên đạt điểm cao nhất trong môn MM02 (nếu có nhiều sinh viên cùng điểm cao nhất thì hiển thị tất cả).
-- Kết quả cần có thêm cột Diem để hiển thị điểm số đó.

SELECT SV.HoTen, SV.Lop, K.Diem
FROM SINHVIEN SV
JOIN KETQUA K ON SV.MaSV = K.MaSV
WHERE K.MaMon = 'MM02'
  AND K.Diem = (SELECT MAX(Diem) FROM KETQUA WHERE MaMon = 'MM02');
