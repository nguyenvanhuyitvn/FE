-- Tạo bảng SINHVIEN
CREATE TABLE SINHVIEN (
    MaSV VARCHAR(10) PRIMARY KEY,
    HoTen VARCHAR(100) NOT NULL,
    NgaySinh DATE,
    Lop VARCHAR(20)
);

-- Tạo bảng KETQUA
CREATE TABLE KETQUA (
    MaSV VARCHAR(10),
    MaMon VARCHAR(10),
    Diem DECIMAL(3,1),
    NgayThi DATE,
    FOREIGN KEY (MaSV) REFERENCES SINHVIEN(MaSV),
    PRIMARY KEY (MaSV, MaMon)
);

